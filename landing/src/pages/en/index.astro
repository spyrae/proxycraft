---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import Hero from '@/components/Hero.astro';
import TrustBar from '@/components/TrustBar.astro';
import ProblemSection from '@/components/ProblemSection.astro';
import ProductCards from '@/components/ProductCards.astro';
import Features from '@/components/Features.astro';
import Platforms from '@/components/Platforms.astro';
import HowItWorks from '@/components/HowItWorks.astro';
import PricingTable from '@/components/PricingTable.astro';
import UseCases from '@/components/UseCases.astro';
import Referral from '@/components/Referral.astro';
import FAQ from '@/components/FAQ.astro';
import FinalCTA from '@/components/FinalCTA.astro';
import Footer from '@/components/Footer.astro';
---

<BaseLayout>
  <Header />
  <main>
    <Hero />
    <TrustBar />
    <ProblemSection />
    <ProductCards />
    <Features />
    <Platforms />
    <HowItWorks />
    <PricingTable />
    <UseCases />
    <Referral />
    <FAQ />
    <FinalCTA />
  </main>
  <Footer />
</BaseLayout>
