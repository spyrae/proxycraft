---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
---

<BaseLayout title="Company Details — ProxyCraft" noindex>
  <Header />
  <main class="pt-28 pb-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6">

      <h1 class="text-3xl font-bold">Company Details</h1>
      <p class="mt-4 text-sm leading-relaxed text-text-muted">
        ProxyCraft is operated by a registered Individual Entrepreneur (Sole Proprietor) under
        Russian law. Below are the full legal details of the operating entity.
      </p>

      <!-- Operator -->
      <h2 class="text-xl font-semibold mt-10">Operator</h2>
      <div class="mt-4 overflow-x-auto rounded-xl border border-border">
        <table class="w-full border-collapse text-sm">
          <tbody class="text-sm">
            <tr class="border-b border-border/50">
              <td class="px-4 py-3 font-medium text-text whitespace-nowrap w-48">Full name</td>
              <td class="px-4 py-3 text-text-muted">Individual Entrepreneur Roman Borisovich Belov<br><span class="text-text-dim text-xs">ИП Белов Роман Борисович</span></td>
            </tr>
            <tr class="border-b border-border/50">
              <td class="px-4 py-3 font-medium text-text">Tax ID (ИНН)</td>
              <td class="px-4 py-3 text-text-muted font-mono">770871362722</td>
            </tr>
            <tr class="border-b border-border/50">
              <td class="px-4 py-3 font-medium text-text">Registration number (ОГРНИП)</td>
              <td class="px-4 py-3 text-text-muted font-mono">322774600177836</td>
            </tr>
            <tr>
              <td class="px-4 py-3 font-medium text-text">Legal address</td>
              <td class="px-4 py-3 text-text-muted">107140, Moscow, 2nd Krasnoselsky lane, 2, apt. 130, Russia</td>
            </tr>
          </tbody>
        </table>
      </div>

      <!-- Banking Details -->
      <div class="mt-10 border-t border-border pt-10">
        <h2 class="text-xl font-semibold">Banking Details</h2>
        <div class="mt-4 overflow-x-auto rounded-xl border border-border">
          <table class="w-full border-collapse text-sm">
            <tbody class="text-sm">
              <tr class="border-b border-border/50">
                <td class="px-4 py-3 font-medium text-text whitespace-nowrap w-48">Bank</td>
                <td class="px-4 py-3 text-text-muted">T-Bank (АО «ТБанк»)</td>
              </tr>
              <tr class="border-b border-border/50">
                <td class="px-4 py-3 font-medium text-text">Bank Tax ID (ИНН)</td>
                <td class="px-4 py-3 text-text-muted font-mono">7710140679</td>
              </tr>
              <tr class="border-b border-border/50">
                <td class="px-4 py-3 font-medium text-text">Account number</td>
                <td class="px-4 py-3 text-text-muted font-mono">40802810100003184716</td>
              </tr>
              <tr class="border-b border-border/50">
                <td class="px-4 py-3 font-medium text-text">BIC (БИК)</td>
                <td class="px-4 py-3 text-text-muted font-mono">044525974</td>
              </tr>
              <tr class="border-b border-border/50">
                <td class="px-4 py-3 font-medium text-text">Correspondent account</td>
                <td class="px-4 py-3 text-text-muted font-mono">30101810145250000974</td>
              </tr>
              <tr>
                <td class="px-4 py-3 font-medium text-text">Bank address</td>
                <td class="px-4 py-3 text-text-muted">127287, Moscow, 2nd Khutorskaya st., 38A, bldg. 26, Russia</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Contact -->
      <div class="mt-10 border-t border-border pt-10">
        <h2 class="text-xl font-semibold">Contact</h2>
        <div class="mt-4 overflow-x-auto rounded-xl border border-border">
          <table class="w-full border-collapse text-sm">
            <tbody class="text-sm">
              <tr class="border-b border-border/50">
                <td class="px-4 py-3 font-medium text-text whitespace-nowrap w-48">Email</td>
                <td class="px-4 py-3">
                  <a href="mailto:info@proxycraft.tech" class="text-accent hover:underline">info@proxycraft.tech</a>
                </td>
              </tr>
              <tr>
                <td class="px-4 py-3 font-medium text-text">Telegram</td>
                <td class="px-4 py-3">
                  <a href="https://t.me/proxycraftapp_bot" class="text-accent hover:underline">@proxycraftapp_bot</a>
                </td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Legal Documents -->
      <div class="mt-10 border-t border-border pt-10">
        <h2 class="text-xl font-semibold">Legal Documents</h2>
        <ul class="mt-3 list-disc pl-6 space-y-2 text-sm text-text-muted">
          <li><a href="/en/terms" class="text-accent hover:underline">Terms of Service</a></li>
          <li><a href="/en/privacy" class="text-accent hover:underline">Privacy Policy</a></li>
          <li><a href="/en/personal-data-consent" class="text-accent hover:underline">Consent to Personal Data Processing</a></li>
          <li><a href="/en/cookies" class="text-accent hover:underline">Cookie Policy</a></li>
        </ul>
      </div>

    </div>
  </main>
  <Footer />
</BaseLayout>
