---
import { getLangFromUrl, t } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const i18n = t(lang);
const botUrl = 'https://t.me/proxycraftapp_bot';
---

<section class="relative overflow-hidden py-20 sm:py-28">
  <!-- Background gradient -->
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-accent/5 to-transparent"></div>

  <div class="relative mx-auto max-w-4xl px-4 sm:px-6">
    <div class="fade-in rounded-2xl border border-accent/20 bg-bg-card p-8 text-center sm:p-12">
      <!-- Glow -->
      <div class="absolute inset-0 rounded-2xl bg-gradient-to-b from-accent/5 to-transparent"></div>

      <div class="relative">
        <h2 class="text-3xl font-bold sm:text-4xl">{i18n.finalCta.title}</h2>
        <p class="mx-auto mt-4 max-w-xl text-lg text-text-muted">{i18n.finalCta.subtitle}</p>

        <div class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
          <a
            href={botUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex min-h-[48px] items-center justify-center gap-2 rounded-xl bg-accent px-8 py-3 text-base font-semibold text-white shadow-lg shadow-accent/25 transition-all hover:bg-accent-light hover:shadow-xl hover:shadow-accent/30"
          >
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
            </svg>
            {i18n.finalCta.cta}
          </a>
          <a
            href={botUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex min-h-[48px] items-center justify-center rounded-xl border border-border px-8 py-3 text-base font-semibold text-text-muted transition-colors hover:border-text-muted hover:text-text"
          >
            {i18n.finalCta.ctaSecondary}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
