---
import { getLangFromUrl, t } from '@/i18n/utils';
import { faqRu, faqEn } from '@/content/faq';

const lang = getLangFromUrl(Astro.url);
const i18n = t(lang);
const faqItems = lang === 'ru' ? faqRu : faqEn;
---

<section id="faq" class="py-20 sm:py-28">
  <div class="mx-auto max-w-3xl px-4 sm:px-6">
    <div class="fade-in text-center">
      <h2 class="text-3xl font-bold sm:text-4xl">{i18n.faq.title}</h2>
    </div>

    <div class="mt-12 space-y-3">
      {faqItems.map((item, i) => (
        <details class="fade-in group rounded-xl border border-border bg-bg-card" style={`transition-delay: ${i * 50}ms`}>
          <summary class="flex items-center justify-between gap-4 px-6 py-4">
            <span class="text-sm font-medium sm:text-base">{item.question}</span>
            <svg class="chevron h-5 w-5 flex-shrink-0 text-text-dim" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
            </svg>
          </summary>
          <div class="border-t border-border px-6 py-4">
            <p class="text-sm leading-relaxed text-text-muted" set:html={item.answer} />
          </div>
        </details>
      ))}
    </div>
  </div>

  <!-- FAQPage Schema.org -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItems.map((item) => ({
      "@type": "Question",
      "name": item.question,
      "acceptedAnswer": { "@type": "Answer", "text": item.answer },
    })),
  })} />
</section>
