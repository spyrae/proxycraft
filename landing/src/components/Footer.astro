---
import { getLangFromUrl, t, getLocalePath } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const i18n = t(lang);
const year = new Date().getFullYear();
const homeUrl = lang === 'ru' ? '/' : '/en/';
const botUrl = 'https://t.me/proxycraftapp_bot';
---

<footer class="border-t border-border py-12">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="grid gap-8 sm:grid-cols-2 md:grid-cols-4">
      <!-- Brand -->
      <div class="sm:col-span-2 md:col-span-1">
        <a href={homeUrl} class="flex items-center gap-2">
          <img src="/logo.svg" alt="ProxyCraft" class="h-7 w-7" />
          <span class="text-lg font-bold">ProxyCraft</span>
        </a>
        <p class="mt-3 text-sm text-text-dim">{i18n.footer.tagline}</p>
      </div>

      <!-- Product -->
      <div>
        <p class="text-sm font-semibold text-text-muted">{i18n.footer.product}</p>
        <ul class="mt-3 space-y-2">
          <li><a href={`${homeUrl}#features`} class="text-sm text-text-dim transition-colors hover:text-text">{i18n.footer.features}</a></li>
          <li><a href={`${homeUrl}#pricing`} class="text-sm text-text-dim transition-colors hover:text-text">{i18n.footer.pricing}</a></li>
          <li><a href={`${homeUrl}#faq`} class="text-sm text-text-dim transition-colors hover:text-text">{i18n.footer.faq}</a></li>
        </ul>
      </div>

      <!-- Support -->
      <div>
        <p class="text-sm font-semibold text-text-muted">{i18n.footer.support}</p>
        <ul class="mt-3 space-y-2">
          <li><a href="mailto:info@proxycraft.tech" class="text-sm text-text-dim transition-colors hover:text-text">{i18n.footer.writeToSupport}</a></li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <p class="text-sm font-semibold text-text-muted">{i18n.footer.legal}</p>
        <ul class="mt-3 space-y-2">
          <li><a href={getLocalePath(lang, '/privacy')} class="text-sm text-text-dim transition-colors hover:text-text">{i18n.footer.privacy}</a></li>
          <li><a href={getLocalePath(lang, '/terms')} class="text-sm text-text-dim transition-colors hover:text-text">{i18n.footer.terms}</a></li>
          <li><a href={getLocalePath(lang, '/cookies')} class="text-sm text-text-dim transition-colors hover:text-text">{i18n.footer.cookiePolicy}</a></li>
          {lang === 'ru' && (
            <li><a href={getLocalePath(lang, '/requisites')} class="text-sm text-text-dim transition-colors hover:text-text">{i18n.footer.requisites}</a></li>
          )}
        </ul>
      </div>
    </div>

    <div class="mt-10 flex flex-col items-center gap-3 border-t border-border pt-6">
      <p class="text-center text-xs text-text-dim">&copy; {year} {i18n.footer.copyright}</p>
      <button
        id="cookie-settings-btn"
        class="text-xs text-text-dim underline transition-colors hover:text-text-muted"
      >
        {i18n.footer.cookieSettings}
      </button>
    </div>

    <script>
      document.getElementById('cookie-settings-btn')?.addEventListener('click', () => {
        try { localStorage.removeItem('cookie_consent'); } catch {}
        location.reload();
      });
    </script>
  </div>
</footer>
