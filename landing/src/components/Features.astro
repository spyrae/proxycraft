---

<section id="features" class="py-20 sm:py-28">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="fade-in text-center">
      <h2 class="text-3xl font-bold sm:text-4xl">{i18n.features.title}</h2>
      <p class="mt-4 text-lg text-text-muted">{i18n.features.subtitle}</p>
    </div>

    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {i18n.features.items.map((item, i) => (
        <div class="fade-in rounded-xl border border-border bg-bg-card p-6 transition-colors hover:border-border-accent" style={`transition-delay: ${i * 50}ms`}>
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-accent/10">
            <svg class="h-6 w-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={iconPaths[item.icon] || iconPaths.speed} />
            </svg>
          </div>
          <h3 class="text-base font-semibold">{item.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-text-muted">{item.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
