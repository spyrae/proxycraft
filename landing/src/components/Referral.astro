---
import { getLangFromUrl, t } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const i18n = t(lang);
const botUrl = 'https://t.me/proxycraftapp_bot';
---

<section class="bg-bg-card/30 py-20 sm:py-28">
  <div class="mx-auto max-w-4xl px-4 sm:px-6">
    <div class="fade-in text-center">
      <h2 class="text-3xl font-bold sm:text-4xl">{i18n.referral.title}</h2>
      <p class="mt-4 text-lg text-text-muted">{i18n.referral.subtitle}</p>
    </div>

    <div class="mt-12 grid gap-6 sm:grid-cols-2">
      <!-- Level 1 -->
      <div class="fade-in rounded-xl border border-accent/30 bg-bg-card p-6 text-center" style="transition-delay: 100ms">
        <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-2xl bg-accent/10">
          <svg class="h-8 w-8 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />
          </svg>
        </div>
        <h3 class="text-lg font-semibold">{i18n.referral.level1.title}</h3>
        <p class="mt-2 text-sm text-text-muted">{i18n.referral.level1.description}</p>
        <div class="mt-4 text-3xl font-extrabold text-accent">{i18n.referral.level1.reward}</div>
      </div>

      <!-- Level 2 -->
      <div class="fade-in rounded-xl border border-border bg-bg-card p-6 text-center" style="transition-delay: 200ms">
        <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-2xl bg-secondary/10">
          <svg class="h-8 w-8 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" />
          </svg>
        </div>
        <h3 class="text-lg font-semibold">{i18n.referral.level2.title}</h3>
        <p class="mt-2 text-sm text-text-muted">{i18n.referral.level2.description}</p>
        <div class="mt-4 text-3xl font-extrabold text-secondary">{i18n.referral.level2.reward}</div>
      </div>
    </div>

    <div class="fade-in mt-10 text-center" style="transition-delay: 300ms">
      <a
        href={botUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex min-h-[44px] items-center justify-center rounded-xl border border-accent px-6 py-3 text-sm font-semibold text-accent transition-colors hover:bg-accent hover:text-white"
      >
        {i18n.referral.cta}
      </a>
    </div>
  </div>
</section>
