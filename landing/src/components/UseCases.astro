---
import { getLangFromUrl } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);

const visuals = [
  // 0: Work tools — ChatGPT, Notion, Figma, Canva, Miro, Claude
  `<div class="grid grid-cols-3 gap-3 w-full max-w-[280px] mx-auto p-2">
    <div class="bg-white/5 aspect-square rounded-2xl flex flex-col items-center justify-center gap-2 shadow-lg border border-white/10 hover:bg-white/10 transition-colors p-3">
      <div class="w-10 h-10 flex items-center justify-center rounded-xl bg-[#10a37f] flex-shrink-0">
        <svg viewBox="0 0 24 24" fill="white" class="w-6 h-6"><path d="M22.282 9.821a5.985 5.985 0 0 0-.516-4.91 6.046 6.046 0 0 0-6.51-2.9A6.065 6.065 0 0 0 4.981 4.18a5.985 5.985 0 0 0-3.998 2.9 6.046 6.046 0 0 0 .743 7.097 5.98 5.98 0 0 0 .51 4.911 6.051 6.051 0 0 0 6.515 2.9A5.985 5.985 0 0 0 13.26 24a6.056 6.056 0 0 0 5.772-4.206 5.99 5.99 0 0 0 3.997-2.9 6.056 6.056 0 0 0-.747-7.073zM13.26 22.43a4.476 4.476 0 0 1-2.876-1.04l.141-.081 4.779-2.758a.795.795 0 0 0 .392-.681v-6.737l2.02 1.168a.071.071 0 0 1 .038.052v5.583a4.504 4.504 0 0 1-4.494 4.494zM3.6 18.304a4.47 4.47 0 0 1-.535-3.014l.142.085 4.783 2.759a.771.771 0 0 0 .78 0l5.843-3.369v2.332a.08.08 0 0 1-.033.062L9.74 19.95a4.5 4.5 0 0 1-6.14-1.646zM2.34 7.896a4.485 4.485 0 0 1 2.366-1.973V11.6a.766.766 0 0 0 .388.676l5.815 3.355-2.02 1.168a.076.076 0 0 1-.071 0l-4.83-2.786A4.504 4.504 0 0 1 2.34 7.872zm16.597 3.855l-5.833-3.387L15.119 7.2a.076.076 0 0 1 .071 0l4.83 2.791a4.494 4.494 0 0 1-.676 8.105v-5.678a.79.79 0 0 0-.407-.667zm2.01-3.023l-.141-.085-4.774-2.782a.776.776 0 0 0-.785 0L9.409 9.23V6.897a.066.066 0 0 1 .028-.061l4.83-2.787a4.5 4.5 0 0 1 6.68 4.66zm-12.64 4.135l-2.02-1.164a.08.08 0 0 1-.038-.057V6.075a4.5 4.5 0 0 1 7.375-3.453l-.142.08-4.778 2.758a.795.795 0 0 0-.393.681zm1.097-2.365l2.602-1.5 2.607 1.5v2.999l-2.597 1.5-2.607-1.5z"/></svg>
      </div>
      <span class="text-[10px] text-white/50">ChatGPT</span>
    </div>
    <div class="bg-white/5 aspect-square rounded-2xl flex flex-col items-center justify-center gap-2 shadow-lg border border-white/10 hover:bg-white/10 transition-colors p-3">
      <div class="w-10 h-10 flex items-center justify-center rounded-xl bg-[#191919] flex-shrink-0">
        <img src="https://cdn.simpleicons.org/notion/ffffff" alt="Notion" class="w-6 h-6" />
      </div>
      <span class="text-[10px] text-white/50">Notion</span>
    </div>
    <div class="bg-white/5 aspect-square rounded-2xl flex flex-col items-center justify-center gap-2 shadow-lg border border-white/10 hover:bg-white/10 transition-colors p-3">
      <div class="w-10 h-10 flex items-center justify-center rounded-xl bg-[#F24E1E] flex-shrink-0">
        <img src="https://cdn.simpleicons.org/figma/ffffff" alt="Figma" class="w-5 h-5" />
      </div>
      <span class="text-[10px] text-white/50">Figma</span>
    </div>
    <div class="bg-white/5 aspect-square rounded-2xl flex flex-col items-center justify-center gap-2 shadow-lg border border-white/10 hover:bg-white/10 transition-colors p-3">
      <div class="w-10 h-10 flex items-center justify-center rounded-xl flex-shrink-0" style="background: linear-gradient(135deg, #7d2ae8, #00c4cc);">
        <span class="text-white font-black text-base leading-none">C</span>
      </div>
      <span class="text-[10px] text-white/50">Canva</span>
    </div>
    <div class="bg-white/5 aspect-square rounded-2xl flex flex-col items-center justify-center gap-2 shadow-lg border border-white/10 hover:bg-white/10 transition-colors p-3">
      <div class="w-10 h-10 flex items-center justify-center rounded-xl bg-[#FFD02F] flex-shrink-0">
        <img src="https://cdn.simpleicons.org/miro/1a1a1a" alt="Miro" class="w-6 h-6" />
      </div>
      <span class="text-[10px] text-white/50">Miro</span>
    </div>
    <div class="bg-white/5 aspect-square rounded-2xl flex flex-col items-center justify-center gap-2 shadow-lg border border-white/10 hover:bg-white/10 transition-colors p-3">
      <div class="w-10 h-10 flex items-center justify-center rounded-xl bg-[#CC785C] flex-shrink-0">
        <img src="https://cdn.simpleicons.org/anthropic/ffffff" alt="Claude" class="w-6 h-6" />
      </div>
      <span class="text-[10px] text-white/50">Claude</span>
    </div>
  </div>`,

  // 1: Social Media — Instagram, Facebook, X, TikTok
  `<div class="grid grid-cols-2 gap-3 w-full max-w-[260px] mx-auto p-2">
    <div class="aspect-square rounded-2xl flex flex-col items-center justify-center gap-2.5 p-4 shadow-xl border border-white/10 bg-gradient-to-br from-purple-600/30 via-pink-500/30 to-orange-400/30 hover:from-purple-600/40 transition-all">
      <img src="https://cdn.simpleicons.org/instagram/white" alt="Instagram" class="w-10 h-10 drop-shadow-lg" />
      <span class="text-[10px] text-white/60 font-medium">Instagram</span>
    </div>
    <div class="aspect-square rounded-2xl flex flex-col items-center justify-center gap-2.5 p-4 shadow-xl border border-white/10 bg-blue-600/20 hover:bg-blue-600/30 transition-all">
      <img src="https://cdn.simpleicons.org/facebook/white" alt="Facebook" class="w-10 h-10 drop-shadow-lg" />
      <span class="text-[10px] text-white/60 font-medium">Facebook</span>
    </div>
    <div class="aspect-square rounded-2xl flex flex-col items-center justify-center gap-2.5 p-4 shadow-xl border border-white/10 bg-white/5 hover:bg-white/10 transition-all">
      <img src="https://cdn.simpleicons.org/x/white" alt="X" class="w-10 h-10 drop-shadow-lg" />
      <span class="text-[10px] text-white/60 font-medium">X (Twitter)</span>
    </div>
    <div class="aspect-square rounded-2xl flex flex-col items-center justify-center gap-2.5 p-4 shadow-xl border border-white/10 bg-white/5 hover:bg-white/10 transition-all">
      <img src="https://cdn.simpleicons.org/tiktok/white" alt="TikTok" class="w-10 h-10 drop-shadow-lg" />
      <span class="text-[10px] text-white/60 font-medium">TikTok</span>
    </div>
  </div>`,

  // 2: Streaming — YouTube, Netflix, Spotify
  `<div class="flex flex-col gap-3 w-full max-w-[280px] mx-auto p-2">
    <div class="flex items-center gap-3 rounded-2xl p-3.5 bg-red-600/15 border border-red-500/20 shadow-lg hover:bg-red-600/25 transition-colors">
      <div class="w-10 h-10 flex items-center justify-center bg-red-600/30 rounded-xl border border-red-500/30 flex-shrink-0">
        <img src="https://cdn.simpleicons.org/youtube/white" alt="YouTube" class="w-6 h-6" />
      </div>
      <div class="flex-1">
        <div class="text-sm font-semibold text-white">YouTube</div>
        <div class="text-xs text-white/50">4K без буферов</div>
      </div>
      <div class="flex items-end gap-0.5 h-5">
        <div class="w-1 rounded-full bg-green-400 h-2"></div>
        <div class="w-1 rounded-full bg-green-400 h-3"></div>
        <div class="w-1 rounded-full bg-green-400 h-5"></div>
        <div class="w-1 rounded-full bg-green-400 h-3"></div>
        <div class="w-1 rounded-full bg-green-400 h-4"></div>
      </div>
    </div>
    <div class="flex items-center gap-3 rounded-2xl p-3.5 bg-red-900/20 border border-red-800/25 shadow-lg hover:bg-red-900/30 transition-colors">
      <div class="w-10 h-10 flex items-center justify-center bg-red-900/40 rounded-xl border border-red-800/30 flex-shrink-0">
        <img src="https://cdn.simpleicons.org/netflix/white" alt="Netflix" class="w-6 h-6" />
      </div>
      <div class="flex-1">
        <div class="text-sm font-semibold text-white">Netflix</div>
        <div class="text-xs text-white/50">Стриминг HD / 4K</div>
      </div>
      <div class="flex items-end gap-0.5 h-5">
        <div class="w-1 rounded-full bg-green-400 h-3"></div>
        <div class="w-1 rounded-full bg-green-400 h-5"></div>
        <div class="w-1 rounded-full bg-green-400 h-2"></div>
        <div class="w-1 rounded-full bg-green-400 h-4"></div>
        <div class="w-1 rounded-full bg-green-400 h-3"></div>
      </div>
    </div>
    <div class="flex items-center gap-3 rounded-2xl p-3.5 bg-green-600/15 border border-green-500/20 shadow-lg hover:bg-green-600/25 transition-colors">
      <div class="w-10 h-10 flex items-center justify-center bg-green-600/30 rounded-xl border border-green-500/30 flex-shrink-0">
        <img src="https://cdn.simpleicons.org/spotify/white" alt="Spotify" class="w-6 h-6" />
      </div>
      <div class="flex-1">
        <div class="text-sm font-semibold text-white">Spotify</div>
        <div class="text-xs text-white/50">Музыка без ограничений</div>
      </div>
      <div class="flex items-end gap-0.5 h-5">
        <div class="w-1 rounded-full bg-green-400 h-4"></div>
        <div class="w-1 rounded-full bg-green-400 h-2"></div>
        <div class="w-1 rounded-full bg-green-400 h-5"></div>
        <div class="w-1 rounded-full bg-green-400 h-3"></div>
        <div class="w-1 rounded-full bg-green-400 h-4"></div>
      </div>
    </div>
  </div>`,

  // 3: Messengers — Telegram chat mock
  `<div class="w-full max-w-[280px] mx-auto space-y-3 py-2">
    <div class="flex items-center gap-2 px-1 mb-4">
      <img src="https://cdn.simpleicons.org/telegram/ffffff" class="w-4 h-4 opacity-70" alt="Telegram" />
      <span class="text-[11px] text-white/40 font-medium tracking-wide">Telegram — Чат с другом</span>
    </div>
    <div class="flex gap-2 items-end" style="max-width: 85%;">
      <div class="w-7 h-7 rounded-full bg-[#26A5E4]/60 flex-shrink-0 flex items-center justify-center text-[11px] font-bold text-white">А</div>
      <div class="bg-white/10 backdrop-blur-sm rounded-2xl rounded-bl-none px-4 py-2.5 border border-white/10 shadow-md">
        <p class="text-[12px] text-white/90 leading-snug">VPN нормально работает? 🤔</p>
        <span class="text-[10px] text-white/30 mt-1 block">14:22</span>
      </div>
    </div>
    <div class="flex gap-2 items-end justify-end">
      <div class="bg-[#2b5278] backdrop-blur-sm rounded-2xl rounded-br-none px-4 py-2.5 border border-[#26A5E4]/20 shadow-md" style="max-width: 85%;">
        <p class="text-[12px] text-white/90 leading-snug text-right">Да, всё летает без лагов 🚀</p>
        <span class="text-[10px] text-white/30 mt-1 block text-right">14:23 ✓✓</span>
      </div>
      <div class="w-7 h-7 rounded-full bg-[#26A5E4]/50 flex-shrink-0 flex items-center justify-center text-[11px] font-bold text-white">Я</div>
    </div>
    <div class="flex gap-2 items-end" style="max-width: 85%;">
      <div class="w-7 h-7 rounded-full bg-[#26A5E4]/60 flex-shrink-0 flex items-center justify-center text-[11px] font-bold text-white">А</div>
      <div class="bg-white/10 backdrop-blur-sm rounded-2xl rounded-bl-none px-4 py-2.5 border border-white/10 shadow-md">
        <p class="text-[12px] text-white/90 leading-snug">Огонь 🔥 Какой тариф взял?</p>
        <span class="text-[10px] text-white/30 mt-1 block">14:24</span>
      </div>
    </div>
  </div>`,

  // 4: Russian Services — Mos.ru, Госуслуги, Nalog.ru, МЭС
  `<div class="grid grid-cols-2 gap-3 w-full max-w-[280px] mx-auto p-2">
    <div class="bg-white/5 aspect-square rounded-2xl flex flex-col items-center justify-center gap-2 shadow-lg border border-white/10 hover:bg-white/10 transition-colors p-4">
      <div class="w-12 h-12 flex items-center justify-center rounded-xl bg-[#c8102e]">
        <span class="text-white font-black text-2xl leading-none">М</span>
      </div>
      <span class="text-[10px] text-white/60 font-medium">mos.ru</span>
    </div>
    <div class="bg-white/5 aspect-square rounded-2xl flex flex-col items-center justify-center gap-2 shadow-lg border border-white/10 hover:bg-white/10 transition-colors p-4">
      <div class="w-12 h-12 flex items-center justify-center rounded-xl bg-[#0079c1]">
        <svg viewBox="0 0 24 24" fill="white" class="w-7 h-7"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 14H4V8l8 5 8-5v10zm-8-7L4 6h16l-8 5z"/></svg>
      </div>
      <span class="text-[10px] text-white/60 font-medium">Госуслуги</span>
    </div>
    <div class="bg-white/5 aspect-square rounded-2xl flex flex-col items-center justify-center gap-2 shadow-lg border border-white/10 hover:bg-white/10 transition-colors p-4">
      <div class="w-12 h-12 flex items-center justify-center rounded-xl bg-[#003d8f]">
        <span class="text-white font-bold text-[14px] tracking-widest">ФНС</span>
      </div>
      <span class="text-[10px] text-white/60 font-medium">Nalog.ru</span>
    </div>
    <div class="bg-white/5 aspect-square rounded-2xl flex flex-col items-center justify-center gap-2 shadow-lg border border-white/10 hover:bg-white/10 transition-colors p-4">
      <div class="w-12 h-12 flex items-center justify-center rounded-xl bg-[#e30713]">
        <svg class="w-6 h-6" fill="white" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.381z" clip-rule="evenodd"></path></svg>
      </div>
      <span class="text-[10px] text-white/60 font-medium text-center leading-tight">Мосэнергосбыт</span>
    </div>
  </div>`,

  // 5: Secure Wi-Fi — protection indicator + location cards
  `<div class="flex flex-col gap-3 w-full max-w-[280px] mx-auto p-2">
    <div class="flex items-center gap-3 bg-green-500/10 rounded-2xl p-4 border border-green-500/20 shadow-lg">
      <div class="w-10 h-10 flex items-center justify-center bg-green-500/20 rounded-xl border border-green-500/30 flex-shrink-0">
        <svg class="w-5 h-5 text-green-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"></path></svg>
      </div>
      <div class="flex-1 min-w-0">
        <div class="text-xs font-semibold text-white">Airport Free Wi-Fi</div>
        <div class="text-[11px] text-green-400 font-medium">🔒 Защищено ProxyCraft</div>
      </div>
      <div class="flex flex-col justify-end gap-0.5 h-5">
        <div class="w-4 h-1 rounded-sm bg-green-400 opacity-30"></div>
        <div class="w-4 h-1.5 rounded-sm bg-green-400 opacity-60"></div>
        <div class="w-4 h-2 rounded-sm bg-green-400"></div>
      </div>
    </div>
    <div class="grid grid-cols-2 gap-2">
      <div class="flex items-center gap-2 bg-white/5 rounded-xl px-3 py-2.5 border border-white/10">
        <span class="text-base leading-none">✈️</span>
        <span class="text-[11px] text-white/70 font-medium">Аэропорты</span>
      </div>
      <div class="flex items-center gap-2 bg-white/5 rounded-xl px-3 py-2.5 border border-white/10">
        <span class="text-base leading-none">☕</span>
        <span class="text-[11px] text-white/70 font-medium">Кафе</span>
      </div>
      <div class="flex items-center gap-2 bg-white/5 rounded-xl px-3 py-2.5 border border-white/10">
        <span class="text-base leading-none">🏨</span>
        <span class="text-[11px] text-white/70 font-medium">Отели</span>
      </div>
      <div class="flex items-center gap-2 bg-white/5 rounded-xl px-3 py-2.5 border border-white/10">
        <span class="text-base leading-none">💼</span>
        <span class="text-[11px] text-white/70 font-medium">Коворкинги</span>
      </div>
    </div>
  </div>`
];

const content = lang === 'ru' ? {
  title: 'Для кого подходит ProxyCraft',
  subtitle: 'Обеспечиваем свободный доступ каждый день',
  cards: [
    {
      title: 'Работа с зарубежными сервисами',
      description: 'Обеспечиваем беспрепятственный доступ к нейросетям, профессиональным инструментам и биржам. Работайте в Canva, создавайте тексты в ChatGPT и организуйте задачи в Notion так, как вам удобно.',
      apps: ['ChatGPT', 'Notion', 'Figma', 'Canva', 'Miro', 'Claude'],
      color: 'from-emerald-500/20 to-teal-500/20'
    },
    {
      title: 'В соцсети без границ',
      description: 'Обеспечиваем свободный доступ к социальным сетям. Листайте Instagram, читайте X (Twitter) и общайтесь в Facebook с высокой скоростью загрузки ленты.',
      apps: ['Instagram', 'Facebook', 'X (Twitter)', 'LinkedIn', 'TikTok'],
      color: 'from-pink-500/20 to-orange-500/20'
    },
    {
      title: 'Видео в 4K и музыка',
      description: 'Смотрите зарубежный YouTube в максимальном качестве, открывайте новинки на Netflix и наслаждайтесь любимыми треками в Spotify без буферизации.',
      apps: ['YouTube', 'Netflix', 'Spotify'],
      color: 'from-red-500/20 to-accent/20'
    },
    {
      title: 'Мессенджеры без ограничений',
      description: 'Общайтесь с родными, друзьями и коллегами. Обеспечиваем стабильный доступ к Telegram, WhatsApp, Discord, Signal и другим привычным средствам связи.',
      apps: ['Telegram', 'WhatsApp', 'Discord', 'Signal'],
      color: 'from-blue-500/20 to-indigo-500/20'
    },
    {
      title: 'Российские сервисы без блокировки',
      description: 'Пользуйтесь домашними сервисами и порталами из любой точки мира. Обеспечиваем свободный доступ к налогам, госуслугам и оплате счетов.',
      apps: ['Nalog.ru', 'Mos.ru', 'Госуслуги', 'Мосэнергосбыт'],
      color: 'from-purple-500/20 to-fuchsia-500/20'
    },
    {
      title: 'Безопасный Wi-Fi где угодно',
      description: 'Защитите свои пароли, переписки и банковские данные при подключении к публичному Wi-Fi в аэропортах, отелях и кафе по всему миру.',
      apps: ['Коворкинги', 'Аэропорты', 'Кафе', 'Отели'],
      color: 'from-accent/20 to-gray-500/20'
    }
  ]
} : {
  title: 'Who is ProxyCraft for?',
  subtitle: 'Providing free access every single day',
  cards: [
    {
      title: 'Work with global platforms',
      description: 'Ensure unrestricted access to AI tools, professional software, and exchanges. Design in Canva, write with ChatGPT, and organize in Notion effortlessly.',
      apps: ['ChatGPT', 'Notion', 'Figma', 'Canva', 'Miro', 'Claude'],
      color: 'from-emerald-500/20 to-teal-500/20'
    },
    {
      title: 'Social media without borders',
      description: 'Providing free access to social networks. Scroll Instagram, read X (Twitter), and chat on Facebook with fast feed loading times.',
      apps: ['Instagram', 'Facebook', 'X (Twitter)', 'LinkedIn', 'TikTok'],
      color: 'from-pink-500/20 to-orange-500/20'
    },
    {
      title: '4K Video & Music Streaming',
      description: 'Watch global YouTube in maximum quality, unlock new releases on Netflix, and enjoy your favorite tracks on Spotify without buffering.',
      apps: ['YouTube', 'Netflix', 'Spotify'],
      color: 'from-red-500/20 to-accent/20'
    },
    {
      title: 'Messengers without limits',
      description: 'Chat with family, friends, and colleagues. We provide stable access to Telegram, WhatsApp, Discord, Signal, and other familiar communication tools.',
      apps: ['Telegram', 'WhatsApp', 'Discord', 'Signal'],
      color: 'from-blue-500/20 to-indigo-500/20'
    },
    {
      title: 'Russian services unblocked',
      description: 'Use your domestic services and portals from anywhere in the world. We ensure simple access to tax, government, and utility portals.',
      apps: ['Nalog.ru', 'Mos.ru', 'Gosuslugi', 'Mosenergosbyt'],
      color: 'from-purple-500/20 to-fuchsia-500/20'
    },
    {
      title: 'Secure Wi-Fi anywhere',
      description: 'Protect your passwords, messages, and banking data when connecting to public Wi-Fi in airports, hotels, and cafes worldwide.',
      apps: ['Coworking', 'Airports', 'Cafes', 'Hotels'],
      color: 'from-accent/20 to-gray-500/20'
    }
  ]
};
---

<section id="usecases" class="py-20 sm:py-28 overflow-hidden">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="fade-in text-center">
      <h2 class="text-3xl font-bold sm:text-4xl">{content.title}</h2>
      <p class="mt-4 text-lg text-text-muted">{content.subtitle}</p>
    </div>

    <div class="mt-16 sm:mt-24 flex flex-col gap-16 sm:gap-32">
      {content.cards.map((card, i) => (
        <div class={`fade-in flex flex-col lg:items-center gap-10 lg:gap-16 ${i % 2 === 1 ? 'lg:flex-row-reverse' : 'lg:flex-row'}`} style={`transition-delay: ${Math.min(i * 50, 200)}ms`}>

          <!-- Text Content Side -->
          <div class="flex-1 space-y-5">
            <h3 class="text-2xl font-bold sm:text-3xl">{card.title}</h3>
            <p class="text-lg text-text-muted leading-relaxed">{card.description}</p>
            <div class="mt-8 flex flex-wrap gap-3">
              {card.apps.map(app => (
                <span class="inline-flex items-center rounded-full bg-border/50 px-4 py-1.5 text-sm font-medium text-text-muted shadow-sm ring-1 ring-border transition-colors hover:text-text hover:bg-bg-card">
                  {app}
                </span>
              ))}
            </div>
          </div>

          <!-- Visual Block Side -->
          <div class="flex-1 w-full max-w-lg mx-auto lg:max-w-none">
            <div class={`relative flex aspect-video sm:aspect-[4/3] lg:aspect-[5/4] w-full flex-col items-center justify-center overflow-hidden rounded-[2rem] border border-border bg-gradient-to-br ${card.color} p-6 sm:p-12 shadow-2xl group`}>

               <div class="relative z-10 w-full flex items-center justify-center">
                 <Fragment set:html={visuals[i]} />
               </div>

               <!-- Decorative glows -->
               <div class="absolute -right-12 top-12 h-40 w-40 rounded-full bg-white/5 blur-3xl transition-transform duration-700 group-hover:scale-150"></div>
               <div class="absolute -left-12 bottom-12 h-48 w-48 rounded-full bg-accent/20 blur-3xl transition-transform duration-700 group-hover:scale-150"></div>
            </div>
          </div>

        </div>
      ))}
    </div>
  </div>
</section>
