# === Bot ===
BOT_TOKEN="1234567890:qwerty"
BOT_DEV_ID=123456789
BOT_SUPPORT_ID=123456789
BOT_ADMINS=123456789
BOT_DOMAIN=proxycraft.example.com

# === 3X-UI ===
XUI_USERNAME=admin
XUI_PASSWORD=admin
# XUI_TOKEN=  # optional, if using token auth
# XUI_SUBSCRIPTION_PORT=2096
# XUI_SUBSCRIPTION_PATH=/user/

# === Shop ===
SHOP_CURRENCY=RUB
SHOP_TRIAL_ENABLED=true
SHOP_TRIAL_PERIOD=7
# SHOP_REFERRER_REWARD_ENABLED=true
# SHOP_REFERRER_LEVEL_ONE_PERIOD=30

# === MTProto ===
# SHOP_MTPROTO_ENABLED=true
# SHOP_MTPROTO_HOST=mtproxy.proxycraft.tech
# SHOP_MTPROTO_LOCATION=Amsterdam
# SHOP_MTPROTO_PORT=8444
# SHOP_MTPROTO_CONFIG_PATH=/app/mtproto/config.py
# SHOP_MTPROTO_TLS_DOMAIN=www.cloudflare.com
# SHOP_MTPROTO_MASK_HOST=www.cloudflare.com
# SHOP_MTPROTO_MASK_PORT=443
# SHOP_MTPROTO_FAST_MODE=true

# === WhatsApp Proxy ===
# SHOP_WHATSAPP_ENABLED=true
# SHOP_WHATSAPP_HOST=proxy.vpncraft.tech
# SHOP_WHATSAPP_LOCATION=Amsterdam
# SHOP_WHATSAPP_PORT_MIN=10001
# SHOP_WHATSAPP_PORT_MAX=10999
# SHOP_WHATSAPP_TLS_CN=proxy.vpncraft.tech
# SHOP_WHATSAPP_TLS_CERT_DAYS=3650

# === Production smoke fixtures ===
# SMOKE_FIXTURE_TG_ID_VPN_AMSTERDAM=990001001
# SMOKE_FIXTURE_TG_ID_VPN_SAINT_PETERSBURG=990001002
# SMOKE_FIXTURE_TG_ID_MTPROTO=990001003
# SMOKE_FIXTURE_TG_ID_WHATSAPP=990001004

# === Production smoke runner (optional fixture overrides) ===
# SMOKE_MTPROTO_SUBSCRIPTION_ID=1
# SMOKE_WHATSAPP_SUBSCRIPTION_ID=1
# SMOKE_VPN_SUBSCRIPTION_ID=1
# SMOKE_VPN_AMSTERDAM_SUBSCRIPTION_ID=1
# SMOKE_VPN_SAINT_PETERSBURG_SUBSCRIPTION_ID=2
# SMOKE_MTPROTO_PROBE_HOST=proxycraft-mtproto
# SMOKE_WHATSAPP_PROBE_HOST=proxycraft-whatsapp
# SMOKE_VPN_PROBE_URL=http://spb01.proxycraft.tech:2096/user/<subscription-id>
# SMOKE_VPN_AMSTERDAM_PROBE_URL=
# SMOKE_VPN_SAINT_PETERSBURG_PROBE_URL=
# SMOKE_TCP_TIMEOUT=5
# SMOKE_HTTP_TIMEOUT=10
# SMOKE_RETRY_COUNT=2

# === External geo probes ===
# GEO_PROBE_PREFERRED_NODES_SEA=sg1.node.check-host.net,id1.node.check-host.net
# GEO_PROBE_PREFERRED_NODES_EU=nl1.node.check-host.net,de1.node.check-host.net
# GEO_PROBE_PREFERRED_NODES_RU_FRIENDLY=kz1.node.check-host.net,am1.node.check-host.net
# GEO_PROBE_HTTP_TIMEOUT=10
# GEO_PROBE_POLL_ATTEMPTS=12
# GEO_PROBE_POLL_INTERVAL=3
# GEO_PROBE_FIXTURE_TIMEOUT=180

# === Payments ===
SHOP_PAYMENT_STARS_ENABLED=true
SHOP_PAYMENT_YOOKASSA_ENABLED=false
# YOOKASSA_TOKEN=
# YOOKASSA_SHOP_ID=

SHOP_PAYMENT_TBANK_ENABLED=false
# TBANK_TERMINAL_KEY=
# TBANK_PASSWORD=

# === Email (Resend) ===
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=noreply@proxycraft.tech

# === SSL (Traefik) ===
LETSENCRYPT_EMAIL=example@email.com
